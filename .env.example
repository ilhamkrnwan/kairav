# =============================================================================
# KAIRAV — Environment Variables
# Salin file ini menjadi .env lalu isi nilainya.
# File .env TIDAK boleh di-commit ke Git.
# =============================================================================


# =============================================================================
# [WAJIB] URL Situs Produksi
# -----------------------------------------------------------------------------
# Isi dengan domain KUSTOM produksi Anda (jika sudah ada custom domain).
# Jika belum, kosongkan — Nuxt akan otomatis memakai VERCEL_URL dari Vercel.
#
# Di Vercel Dashboard → Project → Settings → Environment Variables:
#   - Nama  : NUXT_PUBLIC_SITE_URL
#   - Nilai : https://ilhamkrnwan.com   (ganti dengan domain Anda)
#   - Env   : Production only  ← PENTING, jangan diisi di Preview/Development
#
# Dengan begitu, deployment Preview akan memakai VERCEL_URL secara otomatis
# dan tidak terjadi konflik URL dengan site config i18n.
# =============================================================================
NUXT_PUBLIC_SITE_URL=https://ilhamkrnwan.vercel.app


# =============================================================================
# [OTOMATIS — Disediakan oleh Vercel, tidak perlu diisi manual]
# -----------------------------------------------------------------------------
# Vercel menyuntikkan variabel-variabel berikut secara otomatis pada setiap
# deployment. Anda TIDAK perlu menambahkannya ke Vercel Dashboard.
# Didokumentasikan di sini sebagai referensi saja.
#
#   VERCEL_URL          → URL unik deployment aktif, e.g. kairav-abc123.vercel.app
#   VERCEL_BRANCH_URL   → URL branch deployment, e.g. kairav-git-main.vercel.app
#   VERCEL_ENV          → "production" | "preview" | "development"
#   VERCEL_REGION       → Region tempat fungsi dijalankan, e.g. "sin1"
# =============================================================================
# VERCEL_URL=          # (jangan diisi — otomatis dari Vercel)
# VERCEL_BRANCH_URL=   # (jangan diisi — otomatis dari Vercel)


# =============================================================================
# [OPSIONAL] Variabel Tambahan
# -----------------------------------------------------------------------------
# Tambahkan di sini jika proyek berkembang menggunakan layanan eksternal.
# =============================================================================

# Contoh: Jika menggunakan Supabase di masa depan
# SUPABASE_URL=
# SUPABASE_ANON_KEY=

# Contoh: Jika menggunakan API eksternal lain
# API_SECRET_KEY=

# Cloudinary asset conversion.
# Copy these to .env.local before running pnpm assets:convert-avif.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
